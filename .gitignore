# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/

# Unit test / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Type checkers
.mypy_cache/
.ty/

# Environments
.env
.python-version

# IDE
.idea/
.vscode/

# uv
uv.lock

##### HEAVY ASSETS (downloaded / generated) #####

# Base downloaded assets (models, features, datasets)
models/base/
datasets/base/

# Generated per-wakeword artifacts
models/*/
datasets/*/

# Keep directory structure with .gitkeep
!models/.gitkeep
!datasets/.gitkeep
!configs/.gitkeep

# Generated configs (except template)
configs/*.yaml

# Model / heavy binary files anywhere
*.onnx
*.tflite
*.npy
*.pt
*.pth
*.bin

# Tar / archive downloads
*.tar
*.tar.gz
*.zip

# Notebooks
notebooks/
